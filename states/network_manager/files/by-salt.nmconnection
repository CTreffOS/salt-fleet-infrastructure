[connection]
id=by-salt
uuid=893184eb-101d-42f3-9a83-c64f68932060
type=wifi

[wifi]
mode=infrastructure
ssid=240;159;144;176;32;114;97;98;98;105;116;104;111;108;101;

[wifi-security]
auth-alg=open
key-mgmt=wpa-eap

[802-1x]
ca-cert=/etc/NetworkManager/system-connections/by-salt.pem
eap=ttls;
identity={{ pillar["wifi_radius_credentials"]["username"] }}
password={{ pillar["wifi_radius_credentials"]["password"] }}
phase2-auth=mschapv2

[ipv4]
method=auto

[ipv6]
method=auto
